# --- Donation providers ---
# Copy this file to .env (or .env.local) and fill in your real values.
# Restart `next dev` after editing.

# Zeffy donation form URL (recommended for 501(c)(3) — zero fees).
# Get it from your Zeffy dashboard: https://www.zeffy.com
# Example: https://www.zeffy.com/en-US/donation-form/your-form-id
NEXT_PUBLIC_ZEFFY_DONATION_URL=

# PayPal hosted Donate button.
# Accepts either:
#   1. Just the hosted_button_id (e.g. AB12CD34EF56G), OR
#   2. The full PayPal donate URL (e.g. https://www.paypal.com/donate/?hosted_button_id=...)
# Get it from your PayPal business account → Donations: https://www.paypal.com/donate/buttons
NEXT_PUBLIC_PAYPAL_HOSTED_BUTTON_ID=

# Zelle recipient — the email or US phone registered with your bank's Zelle.
# Donors copy this into their own bank's Zelle app to send. At least one is required
# for the Zelle card to render as active. Both may be provided.
NEXT_PUBLIC_ZELLE_EMAIL=
NEXT_PUBLIC_ZELLE_PHONE=

# --- Donation registration email (Resend) ---
# The donation registration form (/donate/register) emails each submission
# via Resend. Create an API key at https://resend.com/api-keys
# Set this in .env.local — NEVER commit real keys.
RESEND_API_KEY=re_6ACFGSiT_AKv61Nau8qKyhbcEkXgYVkXC

# Recipient of registration emails. Defaults to info@mongolianheritagecenter.org.
DONATION_REGISTER_TO=

# From address. Must be a verified domain/sender in Resend.
# Defaults to "Mongolian Heritage Center <onboarding@resend.dev>" (Resend test
# sender — only delivers to the Resend account owner's email; verify your own
# domain for production).
DONATION_REGISTER_FROM=

# --- Admin section ---
# Password for /admin (donation management). Set in .env.local — NEVER commit.
ADMIN_PASSWORD=

# --- Database ---
# SQLite file used by Prisma (donation registrations). Default: file:./prisma/dev.db
# For production on serverless hosting, switch to a hosted database instead.
# DATABASE_URL=file:./prisma/dev.db

# --- Clerk (admin authentication) ---
# Create an application at https://dashboard.clerk.com then copy both keys.
# When both keys are set, /admin switches from the ADMIN_PASSWORD login
# to Clerk sign-in automatically.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
# Clerk sign-in page lives inside the admin section:
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/admin/login
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/admin/donations
# Comma-separated emails allowed into /admin (required in Clerk mode).
# Signed-in users NOT in this list are denied access.
ADMIN_EMAILS=
# Force redirect to the admin dashboard after sign-in (not the home page):
NEXT_PUBLIC_CLERK_SIGN_IN_FORCE_REDIRECT_URL=/admin/donations
NEXT_PUBLIC_CLERK_SIGN_UP_FORCE_REDIRECT_URL=/admin/donations
